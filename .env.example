# ─────────────────────────────────────────────────────────────────────────────
# DrPrepperUSA Backend — Environment Variables
# Copy to .env and fill in real values before starting the server.
# ─────────────────────────────────────────────────────────────────────────────

# ─── ShipStation Credentials ────────────────────────────────────────────────
# Get these from: ShipStation → Settings → API → API Keys
# One key+secret pair authenticates both V1 (Basic Auth) and V2 (API-Key) calls.

SHIPSTATION_API_KEY=your_shipstation_api_key_here
SHIPSTATION_API_SECRET=your_shipstation_api_secret_here

# Optional: Override ShipStation API base URLs (useful for staging)
# SHIPSTATION_BASE_URL_V1=https://ssapi.shipstation.com
# SHIPSTATION_BASE_URL_V2=https://api.shipstation.com/v2

# ─── Database ───────────────────────────────────────────────────────────────
# Development (default): SQLite file in project root
# DATABASE_URL=dev.sqlite3

# Production (PostgreSQL):
# DATABASE_URL=postgres://user:password@host:5432/drprepperusa

# ─── Server ─────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# CORS: the URL where the React frontend runs (rsbuild dev server)
CLIENT_ORIGIN=http://localhost:3000

# ─── Proxy Authentication ────────────────────────────────────────────────────
# Backend API key for proxy authentication.
# The frontend sends this in the x-api-key header to authenticate with the backend proxy.
# This is NOT the ShipStation API key — it authenticates frontend→backend only.
# Set the same value in:
#   - Server: PROXY_API_KEY (this file / server process.env)
#   - Client: PUBLIC_PROXY_API_KEY (client .env, safe to expose to browser)
PROXY_API_KEY=your_api_key_here

# ─── Logging ────────────────────────────────────────────────────────────────
# Levels: trace | debug | info | warn | error | fatal
LOG_LEVEL=info

# ─────────────────────────────────────────────────────────────────────────────
# IMPORTANT: Never commit .env to git. It's already in .gitignore.
# ─────────────────────────────────────────────────────────────────────────────
