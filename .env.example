# ─────────────────────────────────────────────────────────────────────────────
# Backend vars (Express server — never exposed to browser)
# ─────────────────────────────────────────────────────────────────────────────

# Auth key the backend uses to validate incoming API requests
# Must match PUBLIC_PROXY_API_KEY below
PROXY_API_KEY=your-secret-key-here

# Express server port
PORT=3001

# Allowed frontend origins (comma-separated)
# Local: http://localhost:3000,http://localhost:5173
# Deployed: https://your-app.vercel.app
CLIENT_ORIGIN=http://localhost:3000,http://localhost:5173

# Database connection
# Local dev: sqlite:dev.sqlite3
# Production: postgresql://user:pass@host:5432/dbname
DATABASE_URL=sqlite:dev.sqlite3

# ShipStation credentials (required for sync/labels/rates)
SHIPSTATION_API_KEY=your-shipstation-api-key
SHIPSTATION_API_SECRET=your-shipstation-api-secret

# ─────────────────────────────────────────────────────────────────────────────
# Frontend vars (PUBLIC_ prefix = injected into browser bundle by Rsbuild)
# ─────────────────────────────────────────────────────────────────────────────

# Backend API base URL
# Local: http://localhost:3001/api
# Deployed: https://your-backend.com/api
PUBLIC_API_BASE=http://localhost:3001/api

# Client-to-server auth key (same value as PROXY_API_KEY above)
# Safe to expose to browser — only used to call YOUR backend, not ShipStation
PUBLIC_PROXY_API_KEY=your-secret-key-here
