# ─── ShipStation API Configuration ───────────────────────────────────────────
#
# DrPrepper USA — ShipStation Integration
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to version control.
#
# ⚠️  SECURITY: ShipStation API keys are SERVER-ONLY secrets.
#    They must NOT use the PUBLIC_ prefix (which exposes vars to the browser).
#    These keys should only be read by a server-side proxy or build-time tool.
#    See: docs/PHASE-2-ARCHITECTURE.md — "ShipStation Proxy (PENDING)"
# ─────────────────────────────────────────────────────────────────────────────

# ── ShipStation V1 (Legacy API) ───────────────────────────────────────────────
# Obtain from: https://ship12.shipstation.com/settings/api
# V1 uses Basic Auth: base64(apiKey:apiSecret)
# ⚠️  SERVER-ONLY — never expose to browser (no PUBLIC_ prefix)
SHIPSTATION_API_KEY_V1=your_v1_api_key_here
SHIPSTATION_API_SECRET_V1=your_v1_api_secret_here

# V1 Base URL — only change for staging/testing
# Default: https://ssapi.shipstation.com
# ⚠️  SERVER-ONLY
SHIPSTATION_BASE_URL_V1=https://ssapi.shipstation.com

# ── ShipStation V2 ────────────────────────────────────────────────────────────
# Obtain from: https://app.shipstation.com/settings/api
# V2 uses API key header: API-Key: {your_key}
# ⚠️  SERVER-ONLY — never expose to browser (no PUBLIC_ prefix)
SHIPSTATION_API_KEY_V2=your_v2_api_key_here

# V2 Base URL — only change for staging/testing
# Default: https://api.shipstation.com/v2
# ⚠️  SERVER-ONLY
SHIPSTATION_BASE_URL_V2=https://api.shipstation.com/v2

# ── Cache Configuration ───────────────────────────────────────────────────────
# Rate cache TTL in milliseconds.
# Default: 1800000 (30 minutes)
# Min recommended: 300000 (5 minutes)
# Max recommended: 3600000 (1 hour)
# Note: SERVER-ONLY — not exposed to browser.
CACHE_TTL=1800000

# ── App Configuration ─────────────────────────────────────────────────────────
# Backend API base URL (for order sync, not ShipStation direct)
# This IS safe to expose to the browser (it's a URL, not a secret).
PUBLIC_API_BASE=/api

# ── Development Only ──────────────────────────────────────────────────────────
# Set to 'true' to use mock ShipStation responses instead of real API.
# All services fall back to mock when credentials are missing/empty.
# Automatically true in development mode when keys are empty.
# PUBLIC_USE_MOCK_SHIPSTATION=false
